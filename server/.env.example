# ====================================
# ProfitLabs Server - Environment Variables
# ====================================
# Copy this file to .env and fill in the values
# cp .env.example .env

# ------------------------------------
# Server Configuration
# ------------------------------------
PORT=3001
NODE_ENV=development

# ------------------------------------
# PostgreSQL Database
# ------------------------------------
POSTGRES_URI=postgresql://postgres:[your_password]%40@db.cexeapaxthpfdwndikdb.supabase.co:5432/postgres

# ------------------------------------
# Authentication (JWT)
# ------------------------------------
JWT_SECRET=your-jwt-secret-key-here

# ------------------------------------
# Client URL (Frontend)
# ------------------------------------
CLIENT_URL=http://localhost:5173

# ------------------------------------
# Google OAuth2 (for Google Reviews)
# ------------------------------------
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ------------------------------------
# OpenAI (for AI-powered review replies)
# ------------------------------------
OPENAI_API_KEY=sk-your-openai-api-key

# ------------------------------------
# Razorpay Payment Gateway
# ------------------------------------
RAZORPAY_KEY_ID=rzp_test_your-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret
